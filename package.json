{
  "name": "prism-landing",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node -e \"require('fs').copyFileSync('index.source.html','index.html')\" && vite",
    "build": "node -e \"require('fs').copyFileSync('index.source.html','index.html')\" && vite build",
    "preview": "vite preview",
    "deploy": "node -e \"require('fs').copyFileSync('index.source.html','index.html')\" && vite build && node -e \"var f=require('fs');f.copyFileSync('dist/index.html','index.html');f.cpSync('dist/assets','assets',{recursive:true});f.rmSync('dist',{recursive:true,force:true});\""
  },
  "dependencies": {
    "motion": "^12.10.5",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.4",
    "@vitejs/plugin-react": "^4.3.4",
    "tailwindcss": "^4.1.4",
    "vite": "^6.3.2"
  }
}
